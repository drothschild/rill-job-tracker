-- Job input validation: first failing check wins
rule validation(
  job: { company_name: String, role: String, salary_min: Int, salary_max: Int }
) -> Result(String)

let _ = require(str_len(job.company_name) > 0, "Company name is required")?
let _ = require(str_len(job.role) > 0, "Role is required")?
-- Salary check only applies when both bounds are set (non-zero)
let _ = require(job.salary_min == 0 || job.salary_max == 0 || job.salary_min <= job.salary_max,
                "Minimum salary cannot exceed maximum salary")?
Ok("valid")
